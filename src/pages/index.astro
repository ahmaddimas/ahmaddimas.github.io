---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
    title="Ahmad Dimas Abid Muttaqi — Backend Engineer | Java • Spring Boot"
    description="Backend Engineer with 7+ years in Java, Spring Boot, Kafka, and Docker. 40+ projects delivered across 4 industries. Remote-ready for global roles."
>
    <Navbar />
    <main class="pt-16">
        <!-- Hero Section -->
        <section class="relative min-h-[85vh] flex items-center overflow-hidden max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-20 reveal active">
            <div class="grid md:grid-cols-12 gap-gutter items-center w-full">
                <div class="md:col-span-7 z-10 order-2 md:order-1">
                    <div class="space-y-6">
                        <span class="inline-block font-label-mono text-label-mono text-primary bg-primary-container/10 px-3 py-1 rounded gradient-badge">AVAILABLE FOR REMOTE & FREELANCE</span>
                        <h1 class="font-display-lg text-4xl md:text-display-lg tracking-tight">Ahmad Dimas Abid Muttaqi</h1>
                        <div class="h-10 md:h-12">
                            <span class="font-headline-md md:font-headline-lg text-xl md:text-headline-lg text-secondary typewriter" id="typewriter">Backend </span>
                        </div>
                        <p class="font-body-lg text-body-md md:text-body-lg text-on-surface-variant max-w-xl leading-relaxed">
                            Backend Engineer who ships systems that last. 7+ years building production backends across airline loyalty, insurance, e-commerce, and government systems — with Java, Spring Boot, Kafka, Docker, and cloud-native infrastructure. Delivered 40+ projects, improved code coverage and performance measurably, and remediated security vulnerabilities for monthly production sign-offs.
                        </p>
                        <div class="flex flex-wrap gap-4 pt-4">
                            <a class="bg-inverse-surface text-inverse-on-surface px-8 py-4 rounded font-body-md flex items-center gap-2 hover:bg-on-surface transition-all" href="#projects">
                                View Architecture
                                <svg class="lucide lucide-arrow-right" fill="none" height="18" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="18" xmlns="http://www.w3.org/2000/svg"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                            </a>
                            <a class="border border-outline px-8 py-4 rounded font-body-md flex items-center gap-2 hover:bg-surface-container transition-all" href="https://github.com/ahmaddimas" target="_blank">
                                GitHub
                                <svg class="lucide lucide-github" fill="none" height="18" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="18" xmlns="http://www.w3.org/2000/svg"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="md:col-span-5 relative mb-8 md:mb-0 order-1 md:order-2 float-anim">
                    <div class="relative w-full aspect-[4/5] max-w-[320px] md:max-w-md mx-auto">
                        <img alt="Ahmad Dimas Professional Portrait" class="w-full h-full object-cover hero-mask grayscale hover:grayscale-0 transition-all duration-700" src="/photo.webp">
                    </div>
                </div>
            </div>
        </section>

        <!-- Built for Global Operations -->
        <section class="py-24 bg-surface-container-lowest/50 backdrop-blur-sm border-y border-border-subtle scroll-fade">
            <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="grid md:grid-cols-2 gap-16 items-center">
                    <div>
                        <h2 class="font-headline-lg text-headline-lg mb-6 shuffle-target" data-shuffled="true">Built for Global Operations</h2>
                        <p class="text-secondary mb-8 text-body-lg">3+ years of fully remote experience — working solo across a 6-hour timezone gap with US-based clients and collaborating with distributed teams.</p>
                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <span class="text-primary mt-1">
                                    <svg class="lucide lucide-globe" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"></circle><line x1="2" x2="22" y1="12" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                                </span>
                                <div>
                                    <h4 class="font-bold">Global Async Specialist</h4>
                                    <p class="text-on-surface-variant">Proven track record with US-based B2B platforms, managing complex e-commerce stacks independently.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <span class="text-primary mt-1">
                                    <svg class="lucide lucide-file-text" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" x2="8" y1="13" y2="13"></line><line x1="16" x2="8" y1="17" y2="17"></line><line x1="10" x2="8" y1="9" y2="9"></line></svg>
                                </span>
                                <div>
                                    <h4 class="font-bold">Async-First Philosophy</h4>
                                    <p class="text-on-surface-variant">Heavy emphasis on exhaustive documentation and proactive status reporting to eliminate synchronization bottlenecks.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <span class="text-primary mt-1">
                                    <svg class="lucide lucide-shield-check" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
                                </span>
                                <div>
                                    <h4 class="font-bold">Security-Aware Engineering</h4>
                                    <p class="text-on-surface-variant">Hands-on OWASP remediation in regulated environments with monthly release sign-offs.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4 md:gap-6 stagger-children">
                        <div class="p-6 md:p-8 border border-border-subtle bg-white hover-lift">
                            <span class="text-3xl md:text-display-lg text-primary block mb-2">7+</span>
                            <span class="font-label-mono text-xs uppercase tracking-widest text-secondary">Years Experience</span>
                        </div>
                        <div class="p-6 md:p-8 border border-border-subtle bg-white hover-lift">
                            <span class="text-3xl md:text-display-lg text-primary block mb-2">5</span>
                            <span class="font-label-mono text-xs uppercase tracking-widest text-secondary">Companies</span>
                        </div>
                        <div class="p-6 md:p-8 border border-border-subtle bg-white hover-lift">
                            <span class="text-3xl md:text-display-lg text-primary block mb-2">3+</span>
                            <span class="font-label-mono text-xs uppercase tracking-widest text-secondary">Years Remote</span>
                        </div>
                        <div class="p-6 md:p-8 border border-border-subtle bg-white hover-lift">
                            <span class="text-3xl md:text-display-lg text-primary block mb-2">4</span>
                            <span class="font-label-mono text-xs uppercase tracking-widest text-secondary">Industries</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Engineering Strengths -->
        <section class="py-24 bg-surface/50 backdrop-blur-sm border-b border-border-subtle scroll-fade" id="strengths">
            <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="mb-16">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="text-primary">
                            <svg class="lucide lucide-layers" fill="none" height="36" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="36" xmlns="http://www.w3.org/2000/svg"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
                        </span>
                        <h2 class="font-headline-lg text-headline-lg shuffle-target" data-shuffled="true">Engineering Strengths</h2>
                    </div>
                    <p class="text-secondary mt-2">Core competencies developed through production environments across insurance, government, e-commerce, and airline domains.</p>
                </div>
                <div class="grid md:grid-cols-3 gap-gutter stagger-children">
                    <div class="p-8 border border-border-subtle bg-white card-hover group">
                        <h4 class="font-bold mb-3 flex items-center gap-2">
                            <svg class="lucide lucide-refresh-cw text-primary" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path><path d="M21 3v5h-5"></path><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path><path d="M8 16H3v5"></path></svg>
                            Legacy Modernization
                        </h4>
                        <p class="text-on-surface-variant text-sm leading-relaxed">Strangler-fig pattern migrations, monolith-to-microservices, Java 8 to 17/25 upgrades, zero-downtime deployments.</p>
                    </div>
                    <div class="p-8 border border-border-subtle bg-white card-hover group">
                        <h4 class="font-bold mb-3 flex items-center gap-2">
                            <svg class="lucide lucide-shield text-primary" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg>
                            Security-First
                        </h4>
                        <p class="text-on-surface-variant text-sm leading-relaxed">OWASP remediation, mTLS, JWT/OAuth2, Auth0 integration, SSRF protection, key rotation, pentest clean sign-offs.</p>
                    </div>
                    <div class="p-8 border border-border-subtle bg-white card-hover group">
                        <h4 class="font-bold mb-3 flex items-center gap-2">
                            <svg class="lucide lucide-zap text-primary" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M4 14h7L9 21l11-11h-7l2-7z"></path></svg>
                            Performance Tuning
                        </h4>
                        <p class="text-on-surface-variant text-sm leading-relaxed">N+1 query elimination, cache stampede protection, Redis distributed locks, rate limiting, connection pool optimization.</p>
                    </div>
                    <div class="p-8 border border-border-subtle bg-white card-hover group">
                        <h4 class="font-bold mb-3 flex items-center gap-2">
                            <svg class="lucide lucide-cloud text-primary" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M17.5 19c3.037 0 5.5-2.463 5.5-5.5 0-2.97-2.354-5.382-5.29-5.49A7.001 7.001 0 0 0 5 10c-2.732 0-4.987 2.178-5.05 4.91A4.5 4.5 0 0 0 4.5 19z"></path></svg>
                            Cloud Native
                        </h4>
                        <p class="text-on-surface-variant text-sm leading-relaxed">OpenShift, Docker, Quarkus, AWS S3, multi-stage builds, and containerized deployments.</p>
                    </div>
                    <div class="p-8 border border-border-subtle bg-white card-hover group">
                        <h4 class="font-bold mb-3 flex items-center gap-2">
                            <svg class="lucide lucide-eye text-primary" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            Full Observability
                        </h4>
                        <p class="text-on-surface-variant text-sm leading-relaxed">ELK Stack, APM, Prometheus, Grafana, OpenTelemetry, structured logging (ECS), distributed tracing, health checks.</p>
                    </div>
                    <div class="p-8 border border-border-subtle bg-white card-hover group">
                        <h4 class="font-bold mb-3 flex items-center gap-2">
                            <svg class="lucide lucide-code-2 text-primary" fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" xmlns="http://www.w3.org/2000/svg"><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path></svg>
                            Testing Discipline
                        </h4>
                        <p class="text-on-surface-variant text-sm leading-relaxed">Jacoco enforcement, Testcontainers, JUnit/Mockito, Vitest, integration testing, and CI/CD quality gates.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Professional Experience -->
        <section class="py-24 bg-surface-container-low/50 backdrop-blur-sm scroll-fade" id="experience">
            <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="mb-16">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="text-primary">
                            <svg class="lucide lucide-briefcase" fill="none" height="36" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="36" xmlns="http://www.w3.org/2000/svg"><rect height="14" rx="2" ry="2" width="20" x="2" y="7"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                        </span>
                        <h2 class="font-headline-lg text-headline-lg shuffle-target" data-shuffled="true">Professional Experience</h2>
                    </div>
                    <p class="text-secondary mt-2">A track record of hands-on engineering and architectural growth across diverse domains.</p>
                </div>
                <div class="space-y-16">
                    <!-- Kemenkeu RI -->
                    <div class="grid md:grid-cols-4 gap-8 scroll-fade-left">
                        <div class="md:col-span-1">
                            <span class="font-label-mono text-secondary">Feb 2026 - Present</span>
                            <h4 class="font-bold mt-2 uppercase tracking-wide">Backend Developer</h4>
                            <p class="text-primary text-sm font-bold mt-1">KEMENTERIAN KEUANGAN RI</p>
                        </div>
                        <div class="md:col-span-3 border-l border-border-subtle pl-6 md:pl-12">
                            <ul class="space-y-4 text-on-surface-variant leading-relaxed">
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Developed and maintained backend services using C# and .NET Core for performance assessment systems.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold shrink-0">»</span> <span><span class="text-primary font-bold">Optimized slow API responses</span> by replacing LIKE-based queries with indexed JOINs, selecting only required columns, eliminating unused EF relationship includes, and introducing caching.</span></li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Remediated broken access control vulnerabilities in REST APIs to enforce proper authorization and secure sensitive employee data.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Operated fully remote within a distributed government enterprise team.</li>
                            </ul>
                            <div class="flex flex-wrap gap-2 mt-8">
                                <span class="tech-tag">C#</span><span class="tech-tag">.NET Core</span><span class="tech-tag">Entity Framework</span><span class="tech-tag">SQL Server</span><span class="tech-tag">Docker</span>
                            </div>
                        </div>
                    </div>
                    <!-- AXA Mandiri -->
                    <div class="grid md:grid-cols-4 gap-8 scroll-fade-right">
                        <div class="md:col-span-1">
                            <span class="font-label-mono text-secondary">Nov 2023 - Apr 2026</span>
                            <h4 class="font-bold mt-2 uppercase tracking-wide">Backend Developer</h4>
                            <p class="text-primary text-sm font-bold mt-1">AXA MANDIRI FINANCIAL SERVICES</p>
                        </div>
                        <div class="md:col-span-3 border-l border-border-subtle pl-6 md:pl-12">
                            <ul class="space-y-4 text-on-surface-variant leading-relaxed">
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Led incremental migration of legacy services to Red Hat OpenShift using strangler-fig pattern.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Remediated OWASP security vulnerabilities identified by pentesters before every monthly deployment.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold shrink-0">»</span> <span><span class="text-primary font-bold">Raised code coverage from below 30% to 80%+</span> by integrating JUnit/Mockito test suites.</span></li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Built centralized observability from scratch: ELK Stack with APM for log correlation and distributed tracing.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Containerized microservices with Docker for deployment on on-premise Linux infrastructure via Red Hat OpenShift, eliminating environment drift between development and production.</li>
                            </ul>
                            <div class="flex flex-wrap gap-2 mt-8">
                                <span class="tech-tag">Java</span><span class="tech-tag">Spring Boot</span><span class="tech-tag">Spring Cloud Gateway</span><span class="tech-tag">Quarkus</span><span class="tech-tag">OpenShift</span><span class="tech-tag">Docker</span><span class="tech-tag">Kafka</span><span class="tech-tag">AWS MSK</span><span class="tech-tag">AWS S3</span><span class="tech-tag">ELK Stack</span><span class="tech-tag">SQL Server</span><span class="tech-tag">MongoDB</span><span class="tech-tag">JUnit/Mockito</span><span class="tech-tag">Linux</span>
                            </div>
                        </div>
                    </div>
                    <!-- Lime Commerce -->
                    <div class="grid md:grid-cols-4 gap-8 scroll-fade-left">
                        <div class="md:col-span-1">
                            <span class="font-label-mono text-secondary">Jun 2020 - Nov 2023</span>
                            <h4 class="font-bold mt-2 uppercase tracking-wide">Full-Stack Developer</h4>
                            <p class="text-primary text-sm font-bold mt-1">LIME COMMERCE (REMOTE US CLIENT)</p>
                        </div>
                        <div class="md:col-span-3 border-l border-border-subtle pl-6 md:pl-12">
                            <ul class="space-y-4 text-on-surface-variant leading-relaxed">
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Sole developer for Bramble Company (US-based), working fully independently across 6-hour TZ gap.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold shrink-0">»</span> <span><span class="text-primary font-bold">Improved PageSpeed score from below 35 to 90+</span> through intensive asset optimization.</span></li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Migrated production Magento 1 store to Magento 2, including data and custom extension porting.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Built and customized 10+ Magento 2 extensions across the full e-commerce stack.</li>
                            </ul>
                            <div class="flex flex-wrap gap-2 mt-8">
                                <span class="tech-tag">PHP</span><span class="tech-tag">Magento 2</span><span class="tech-tag">Linux</span><span class="tech-tag">MySQL</span><span class="tech-tag">REST APIs</span>
                            </div>
                        </div>
                    </div>
                    <!-- DOT Indonesia -->
                    <div class="grid md:grid-cols-4 gap-8 scroll-fade-right">
                        <div class="md:col-span-1">
                            <span class="font-label-mono text-secondary">Jul 2019 - Apr 2020</span>
                            <h4 class="font-bold mt-2 uppercase tracking-wide">Backend Developer</h4>
                            <p class="text-primary text-sm font-bold mt-1">DOT INDONESIA</p>
                        </div>
                        <div class="md:col-span-3 border-l border-border-subtle pl-6 md:pl-12">
                            <ul class="space-y-4 text-on-surface-variant leading-relaxed">
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Built RESTful APIs for OSVAS (One Space Canvas), a real estate discovery platform.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Developed applications using PHP, Laravel, and Laravel Nova within an Agile environment.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Integrated with frontend teams via a DevOps-managed CI/CD pipeline.</li>
                            </ul>
                            <div class="flex flex-wrap gap-2 mt-8">
                                <span class="tech-tag">PHP</span><span class="tech-tag">Laravel</span><span class="tech-tag">Laravel Nova</span><span class="tech-tag">MySQL</span><span class="tech-tag">REST APIs</span><span class="tech-tag">CI/CD</span>
                            </div>
                        </div>
                    </div>
                    <!-- Aero Systems -->
                    <div class="grid md:grid-cols-4 gap-8 scroll-fade-left">
                        <div class="md:col-span-1">
                            <span class="font-label-mono text-secondary">Jul 2018 - Jul 2019</span>
                            <h4 class="font-bold mt-2 uppercase tracking-wide">Software Engineer</h4>
                            <p class="text-primary text-sm font-bold mt-1">PT. AERO SYSTEMS INDONESIA</p>
                        </div>
                        <div class="md:col-span-3 border-l border-border-subtle pl-6 md:pl-12">
                            <ul class="space-y-4 text-on-surface-variant leading-relaxed">
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Delivered AMALA Loyalty Management System for Garuda Indonesia and Citilink.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Integrated Apache Camel for enterprise workflow automation.</li>
                                <li class="flex gap-3"><span class="text-primary font-bold">»</span> Deployed services using Docker and Kubernetes for high-scale airline operations.</li>
                            </ul>
                            <div class="flex flex-wrap gap-2 mt-8">
                                <span class="tech-tag">Java</span><span class="tech-tag">Spring Boot</span><span class="tech-tag">Apache Camel</span><span class="tech-tag">Docker</span><span class="tech-tag">Kubernetes</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Education Section -->
        <section class="py-24 bg-surface/50 backdrop-blur-sm border-t border-border-subtle scroll-fade" id="education">
            <div class="max-w-max-width mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="mb-16">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="text-primary">
                            <svg class="lucide lucide-graduation-cap" fill="none" height="36" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="36" xmlns="http://www.w3.org/2000/svg"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
                        </span>
                        <h2 class="font-headline-lg text-headline-lg shuffle-target" data-shuffled="true">Education</h2>
                    </div>
                    <p class="text-secondary mt-2">Academic foundation in computer science and information technology.</p>
                </div>
